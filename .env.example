# Discord Bot Configuration (Required)
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
CLIENT_SECRET=your_discord_client_secret_here

# Environment Configuration
NODE_ENV=production

# Infisical (Optional – when set, secrets are loaded from Infisical after .env)
# Create a Machine Identity in Infisical and set these to pull secrets at runtime.
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENV=dev
# INFISICAL_SECRET_PATH=/
# INFISICAL_SITE_URL=

# Bot Customization (Optional)
BOT_NAME=Lucky
BOT_DESCRIPTION=A modern Discord bot for music playback and downloads
BOT_AVATAR_URL=
BOT_COLOR=0x5865F2
BOT_WEBSITE=
BOT_SUPPORT_SERVER=

# Optional: Disable specific commands (comma-separated)
# Example: COMMANDS_DISABLED=ping,help
COMMANDS_DISABLED=

# Optional: Disable specific command categories (comma-separated)
# Available categories: download, general, music
# Example: COMMAND_CATEGORIES_DISABLED=download
COMMAND_CATEGORIES_DISABLED=

# Optional: Sentry DSN for error tracking and monitoring
# SENTRY_DSN=your_sentry_dsn_here

# Logging Configuration
LOG_LEVEL=1

# Database Configuration (Optional - bot will work without database using Redis fallback)
DATABASE_URL=postgresql://username:password@localhost:5432/discordbot
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECTION_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=10000

# Redis Configuration (Optional - bot will work without Redis using in-memory fallback)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Twitch Configuration (Optional - for stream-online notifications)
# Create an app at https://dev.twitch.tv/console and use client ID + secret.
# EventSub WebSocket requires a user access token (see docs/TWITCH_SETUP.md).
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_ACCESS_TOKEN=   # User OAuth token (required for EventSub)
# TWITCH_REFRESH_TOKEN=  # User OAuth refresh token (optional, for auto-refresh)

# Last.fm API (Optional - for scrobbling and now playing)
# Get API key and secret at https://www.last.fm/api/account/create
# Users link their own accounts via /lastfm link; optional fallback for global scrobbling (see docs/LASTFM_SETUP.md).
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_SESSION_KEY=
# Signing secret for Last.fm connect link (use LASTFM_LINK_SECRET or WEBAPP_SESSION_SECRET)
# LASTFM_LINK_SECRET=

# TikTok Configuration (Optional - for download optimization)
TIKTOK_API_HOSTNAME=api16-normal-c-useast1a.tiktokv.com
TIKTOK_REFERER_URL=https://www.tiktok.com/
TIKTOK_EXTRACTOR_RETRIES=3
TIKTOK_FRAGMENT_RETRIES=3
TIKTOK_SLEEP_INTERVAL=1
TIKTOK_MAX_SLEEP_INTERVAL=3

# YouTube Configuration (Optional - for processing optimization)
YOUTUBE_CONNECTION_TIMEOUT=120000
YOUTUBE_MAX_RETRIES=3
YOUTUBE_RETRY_DELAY=1000
YOUTUBE_MAX_EXTRACTORS=5
YOUTUBE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# Rate Limiting Configuration (Optional - for abuse prevention)
RATE_LIMIT_COMMAND_WINDOW_MS=60000
RATE_LIMIT_COMMAND_MAX_REQUESTS=5
RATE_LIMIT_MUSIC_COMMAND_WINDOW_MS=30000
RATE_LIMIT_MUSIC_COMMAND_MAX_REQUESTS=3
RATE_LIMIT_DOWNLOAD_WINDOW_MS=300000
RATE_LIMIT_DOWNLOAD_MAX_REQUESTS=2

# Session Configuration (Optional - for session management)
USER_SESSION_TTL=86400
QUEUE_SESSION_TTL=7200
COMMAND_HISTORY_LIMIT=10

# Cache Configuration (Optional - for performance tuning)
CACHE_TRACK_INFO_SIZE=2000
CACHE_ARTIST_TITLE_SIZE=2000
CACHE_MEMO_SIZE=5000
CACHE_TTL_HOURS=1

# Player Configuration (Optional - for music player settings)
PLAYER_LEAVE_ON_EMPTY_COOLDOWN=300000
PLAYER_LEAVE_ON_END_COOLDOWN=300000
PLAYER_CONNECTION_TIMEOUT=5000
MUSIC_WATCHDOG_TIMEOUT_MS=25000
MUSIC_PROVIDER_COOLDOWN_MS=120000
MUSIC_SESSION_RESTORE_ENABLED=true
AUTOPLAY_DISLIKE_TTL_HOURS=24

# Download Configuration (Optional - for download settings)
DOWNLOAD_TIMEOUT=10000
DOWNLOAD_MAX_RETRIES=3
DOWNLOAD_RETRY_DELAY=1000

# Search Configuration (Optional - for search settings)
SEARCH_TIMEOUT=15000
SEARCH_RETRY_DELAY=5000

# Feature Toggles
# Enable/disable features using environment variables (default: true for all)
# Format: FEATURE_<TOGGLE_NAME>=true|false
# Available toggles: DOWNLOAD_VIDEO, DOWNLOAD_AUDIO, MUSIC_RECOMMENDATIONS, AUTOPLAY, LYRICS, QUEUE_MANAGEMENT, REACTION_ROLES, ROLE_MANAGEMENT
# FEATURE_DOWNLOAD_VIDEO=true
# FEATURE_DOWNLOAD_AUDIO=true
# FEATURE_MUSIC_RECOMMENDATIONS=true
# FEATURE_AUTOPLAY=true
# FEATURE_LYRICS=true
# FEATURE_QUEUE_MANAGEMENT=true
# FEATURE_REACTION_ROLES=true
# FEATURE_ROLE_MANAGEMENT=true

# Unleash Feature Flag Service (Optional)
# If not configured, feature toggles will use environment variables as fallback
# UNLEASH_URL=http://localhost:4242/api
# UNLEASH_API_TOKEN=your_unleash_api_token
# UNLEASH_APP_NAME=lucky
# UNLEASH_ENVIRONMENT=development
# UNLEASH_BOOTSTRAP_DATA={"features":[]}

# Web Application (Optional)
# Enable web application for feature toggle management
# WEBAPP_ENABLED=false
# WEBAPP_PORT=3000
# WEBAPP_FRONTEND_URL=http://localhost:5173
# WEBAPP_BACKEND_URL=http://localhost:3000
# WEBAPP_REDIRECT_URI=http://localhost:3000/api/auth/callback
# DEVELOPER_USER_IDS=your_discord_user_id
#
# Production / Cloudflare Tunnel
# WEBAPP_FRONTEND_URL=https://lucky.lucassantana.tech,https://lukbot.vercel.app
# WEBAPP_BACKEND_URL=https://lucky-api.lucassantana.tech
# WEBAPP_REDIRECT_URI=https://lucky-api.lucassantana.tech/api/auth/callback
# WEBAPP_EXPECTED_CLIENT_ID=962198089161134131
# WEBAPP_SESSION_SECRET=generate-a-random-64-char-string
# POSTGRES_PASSWORD=change-me-in-production
# NGINX_PORT=8080
#
# Cloudflare Tunnel (exposes homelab without port forwarding)
# Create: cloudflared tunnel create lucky
# Route:  cloudflared tunnel route dns lucky lucky.lucassantana.tech
# CLOUDFLARED_CONFIG_DIR=/home/luk-server/.cloudflared
# Must contain config-lucky.yml and the tunnel credentials JSON file.
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token

# Dependency Check Service (Optional)
# Enable automated dependency update notifications via Discord webhook
# DEPENDENCY_CHECK_ENABLED=false
# DEPENDENCY_WEBHOOK_URL=your_discord_webhook_url
# DEPENDENCY_CHECK_INTERVAL=86400000
# DEPENDENCY_NOTIFY_ONLY_SECURITY=false
