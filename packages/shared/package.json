{
    "name": "@lucky/shared",
    "version": "1.0.0",
    "description": "Shared code for Lucky modular monolith",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./config": {
            "types": "./dist/config/index.d.ts",
            "default": "./dist/config/index.js"
        },
        "./services": {
            "types": "./dist/services/index.d.ts",
            "default": "./dist/services/index.js"
        },
        "./services/*": {
            "types": "./dist/services/*.d.ts",
            "default": "./dist/services/*.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "default": "./dist/utils/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.js"
        }
    },
    "scripts": {
        "build": "tsc -b --force && node add-js-extensions.js",
        "dev": "tsc --watch",
        "type:check": "tsc --noEmit"
    },
    "dependencies": {
        "@gar/promise-retry": "^1.0.2",
        "@npmcli/agent": "^4.0.0",
        "@npmcli/fs": "^5.0.0",
        "@prisma/client": "^7.4.2",
        "@sentry/node": "^10.37.0",
        "axios": "^1.13.2",
        "chalk": "^5.6.2",
        "dotenv": "^17.2.3",
        "fs-minipass": "^3.0.3",
        "ioredis": "^5.9.2",
        "minipass": "^7.1.3",
        "minipass-collect": "^2.0.1",
        "minipass-fetch": "^5.0.2",
        "minipass-flush": "^1.0.5",
        "minipass-pipeline": "^1.2.4",
        "negotiator": "^1.0.0",
        "proc-log": "^6.1.0",
        "ssri": "^13.0.1",
        "unique-filename": "^5.0.0",
        "unleash-client": "^6.10.1",
        "uuid": "^13.0.0",
        "zod": "^3.25.76"
    },
    "optionalDependencies": {
        "@infisical/sdk": "^4.0.0"
    },
    "devDependencies": {
        "@swc/cli": "^0.7.10",
        "@swc/core": "^1.15.8",
        "@types/node": "^25.1.0",
        "glob": "^7.2.3",
        "typescript": "^5.9.3"
    }
}
