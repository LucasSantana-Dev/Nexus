{
    "name": "@lucky/bot",
    "version": "1.0.0",
    "description": "Discord bot application",
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "preflight": "npm --prefix ../.. run db:generate && npm --prefix ../.. run build:shared",
        "build": "npm run preflight && tsc && node add-js-extensions.js",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "type:check": "npm run preflight && tsc --noEmit",
        "test": "jest",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@discord-player/extractor": "^7.2.0",
        "@discordjs/builders": "^1.13.1",
        "@lucky/shared": "file:../shared",
        "@sentry/node": "^10.38.0",
        "chalk": "^5.6.2",
        "discord-player": "^7.1.0",
        "discord-player-youtubei": "^2.0.0-dev.2",
        "discord.js": "^14.25.1",
        "dotenv": "^17.2.3",
        "ffmpeg-static": "^5.3.0",
        "opusscript": "^0.1.1",
        "play-dl": "^1.9.7",
        "ws": "^8.19.0",
        "youtubei.js": "^16.0.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^25.1.0",
        "@types/ws": "^8.5.13",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
