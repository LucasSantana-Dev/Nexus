{
    "name": "lucky-webapp",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint . --config eslint.config.js --max-warnings 0",
        "type:check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "check:deps": "tsx scripts/check-dependencies.ts",
        "check:deps:security": "DEPENDENCY_NOTIFY_ONLY_SECURITY=true tsx scripts/check-dependencies.ts",
        "check:deps:simple": "npx npm-check-updates",
        "check:outdated": "npm outdated"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.0.0",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.1.5",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-query": "^5.90.21",
        "axios": "^1.13.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.0.0",
        "lucide-react": "^0.577.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.68.0",
        "react-router-dom": "^7.13.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.0.0",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.25.76",
        "zustand": "^5.0.2"
    },
    "overrides": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@tailwindcss/postcss": "^4.1.18",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/three": "^0.183.0",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "@vitejs/plugin-react": "^5.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^10.0.0",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.5.0",
        "jsdom": "^28.1.0",
        "playwright": "^1.57.0",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.0",
        "vitest": "^4.0.18"
    }
}
